{
  "regions": ["icn1"],
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/att/cancel",     "destination": "/api/att/request?__op=cancel" },
    { "source": "/api/att/pending",    "destination": "/api/att/request?__op=pending" },
    { "source": "/api/auth/pending",   "destination": "/api/auth/signup?__op=pending" },
    { "source": "/api/auth/ip-groups", "destination": "/api/auth/signup?__op=ip-groups" }
  ],
  "crons": [
    { "path": "/api/cron/notify-off", "schedule": "1 15 * * *" },
    { "path": "/api/cron/notify-off", "schedule": "30 22 * * *" }
  ],
  "headers": [
    {
      "source": "/((?!.*\\.(?:png|jpg|jpeg|webp|gif|svg|ico|css|js|woff|woff2|ttf|otf|eot|map)).*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=0, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
